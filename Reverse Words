class Solution {
    public String reverseWords(String s) {
        String[] c=s.split("\\.+");
        StringBuilder sb=new StringBuilder();
        for(int i=c.length-1;i>=0;i--){
            if(!c[i].isEmpty()){
                if(sb.length()>0){
                    sb.append(".");
                }
                sb.append(c[i]);
            }
        }
        return sb.toString();
    }
}
